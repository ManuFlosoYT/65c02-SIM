{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 24,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "linux-release",
            "displayName": "Linux Release",
            "description": "Release build for Linux using Ninja",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "linux-debug",
            "displayName": "Linux Debug",
            "description": "Debug build for Linux using Ninja",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "linux-perfdebug",
            "displayName": "Linux PerfDebug",
            "description": "Optimized debug-symbol build for profiling (no strip)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/perfdebug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "PerfDebug",
                "PERFDEBUG_ENABLE_LTO": "OFF"
            }
        },
        {
            "name": "linux-perfdebug-lto",
            "displayName": "Linux PerfDebug + LTO",
            "description": "PerfDebug build with LTO enabled",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/perfdebug-lto",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "PerfDebug",
                "PERFDEBUG_ENABLE_LTO": "ON"
            }
        },
        {
            "name": "windows-release",
            "displayName": "Windows Release (MinGW)",
            "description": "Cross-compile Release build for Windows using MinGW",
            "generator": "Ninja",
            "toolchainFile": "${sourceDir}/cmake/mingw-toolchain.cmake",
            "binaryDir": "${sourceDir}/build_win/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "windows-debug",
            "displayName": "Windows Debug (MinGW)",
            "description": "Cross-compile Debug build for Windows using MinGW",
            "generator": "Ninja",
            "toolchainFile": "${sourceDir}/cmake/mingw-toolchain.cmake",
            "binaryDir": "${sourceDir}/build_win/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "windows-perfdebug",
            "displayName": "Windows PerfDebug (MinGW)",
            "description": "Cross-compile optimized debug-symbol build for profiling (no strip)",
            "generator": "Ninja",
            "toolchainFile": "${sourceDir}/cmake/mingw-toolchain.cmake",
            "binaryDir": "${sourceDir}/build_win/perfdebug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "PerfDebug",
                "PERFDEBUG_ENABLE_LTO": "OFF"
            }
        },
        {
            "name": "windows-perfdebug-lto",
            "displayName": "Windows PerfDebug + LTO (MinGW)",
            "description": "Cross-compile PerfDebug build with LTO enabled",
            "generator": "Ninja",
            "toolchainFile": "${sourceDir}/cmake/mingw-toolchain.cmake",
            "binaryDir": "${sourceDir}/build_win/perfdebug-lto",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "PerfDebug",
                "PERFDEBUG_ENABLE_LTO": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "linux-release",
            "configurePreset": "linux-release"
        },
        {
            "name": "linux-debug",
            "configurePreset": "linux-debug"
        },
        {
            "name": "linux-perfdebug",
            "configurePreset": "linux-perfdebug"
        },
        {
            "name": "linux-perfdebug-lto",
            "configurePreset": "linux-perfdebug-lto"
        },
        {
            "name": "windows-release",
            "configurePreset": "windows-release"
        },
        {
            "name": "windows-debug",
            "configurePreset": "windows-debug"
        },
        {
            "name": "windows-perfdebug",
            "configurePreset": "windows-perfdebug"
        },
        {
            "name": "windows-perfdebug-lto",
            "configurePreset": "windows-perfdebug-lto"
        }
    ]
}
